# Path to the local ChromaDB vector database directory
CHROMA_DB_PATH=../chroma_db

# Host address to bind the API server (0.0.0.0 exposes it to all local network interfaces)
API_HOST=0.0.0.0

# The port the FastAPI server will listen on
API_PORT=8000

# Allowed CORS origins, comma-separated (Add your Vercel URL here in production)
CORS_ORIGINS=https://hibiki-37av1lly-ife-cybs-projects.vercel.app
